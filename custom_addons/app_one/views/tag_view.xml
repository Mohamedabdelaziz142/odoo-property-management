<odoo>
    <record id="tag_view_tree" model="ir.ui.view">
        <field name="name">tag tree</field>
        <field name="model">app_one.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="tag_form_view" model="ir.ui.view">
        <field name="name">tag form</field>
        <field name="model">app_one.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Tag Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="property_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">app_one.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem 
        id="tag_menu_item" 
        name="Tags" 
        parent="configuration_menu" 
        action="tag_action"/>
</odoo>