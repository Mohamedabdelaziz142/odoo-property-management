<odoo>
    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property tree</field>
        <field name="model">app_one.property</field>
        <field name="arch" type="xml">
            <tree class="header_custom" decoration-danger="is_lated">
                        <field name="name"/>
                        <field name="postcode"/>
                        <field name="owner_id"/>
                        <field name="description"/>
                        <field name="state"/> 
                        <field name="date_available"/>
                        <field name="expected_selling_date"/>
                        <field name="is_lated" invisible="1"/>
                        <field name="selling_price"/>
                        <field name="bedrooms"/>
                        <field name="garden" optional="1"/>
                        <field name="garage" optional="1"/>
                        <field name="active"/>

                        
            </tree>
        </field>
    </record>

   <record id="property_form_view" model="ir.ui.view">
        <field name="name">property form</field>
        <field name="model">app_one.property</field>
        <field name="arch" type="xml">
            <form>

              <header>
                    <button name="action_draft" string="Set to Draft" type="object" class="btn-primary" invisible="state == 'draft'"/>
                    <button name="action_pending" string="Pending" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_sold" string="Sold" type="object" class="btn-success" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar" />
                    </header>
                <sheet>
                    <div class="oe_title">
                    
                        <label for="ref"/>

                        <h1>
                            <field name="ref"/>
                        </h1>
                    
                        <label for="name" class="oe_edit_only"/>
                        <h3>
                            <field name="name" placeholder="Property Name"/>
                        </h3>
                     </div>
                    <group string="Property Details">
                        <group>
                          <field name="date_available" required="1"/>
                          <field name="expected_selling_date"/>   
                          <field name="is_lated" invisible="1"/>
                          <field name="selling_price"/>
                          <field name="expected_price"/>
                          <field name="difference"/>
                          <field name="postcode"/>
                          <field name="facades"/>
                          <field name="garden"/>
                          <field name="bedrooms"/>
                      </group>
                       <group string="Additional Information">                        
                          <field name="garage"/>  
                          <field name="owner_id"/>
                          <field name="owner_address"/>
                          <field name="owner_phone"/>  
                          <field name="garden_orientation"/>
                          <field name="active"/>
                          <field name="garden_area"/>                                                
                          <field name="tag_ids" widget="many2many_tags"/>
                       </group>
                       <group>                       
                         <field name="description" required="1"/>                    
                      </group>
                    </group>

                    <notebook>
                        <page string="Bedrooms">
                            <field name="lines_ids">
                                  <tree editable="bottom">
                                      <field name="description"/>
                                      <field name="area"/>
                                  </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
                </div>
            </form>
        </field>
    </record>

<record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">app_one.property</field>
        <field name="arch" type="xml">
            <search>      
                <field name="postcode"/>  
                <field name="name"/> 

                <filter name="is_garden" string="With Garden" domain="[('garden','=',True)]"/>
                <filter name="is_not_garden" string="Without Garden" domain="[('garden','=',False)]"/>
                <filter name="is_garage" string="With Garage" domain="[('garage','=',True)]"/>
                <filter name="is_not_garage" string="Without Garage" domain="[('garage','=',False)]"/>

                <filter name="garden_group" string="Garden" context="{'group_by': 'garden'}"/>
            </search>
        </field>
    </record>
    
    <record id="property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">app_one.property</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_state': 1}</field>
    </record>

    <record id="property_closed_action" model="ir.actions.server">
        <field name="name">Close Property</field>
        <field name="model_id" ref="model_app_one_property"/>
        <field name="binding_model_id" ref="model_app_one_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>

    <record id="check_selling_date_cron" model="ir.cron">
        <field name="name">Property: Check Selling Date</field>
        <field name="model_id" ref="model_app_one_property"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="state">code</field>
        <field name="active" eval="True"/>
        <field name="code">
            model.cheack_expected_date()
        </field>
    </record>

    <menuitem 
    id="property_menu_item" 
    name="Properties" 
    parent="properties_menu" 
    action="property_action"/>
</odoo>
